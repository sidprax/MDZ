{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"<MDZ_ROOT>/adapters/claude/hooks/mdz-hook.mjs\"",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"<MDZ_ROOT>/adapters/claude/hooks/mdz-hook.mjs\"",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"<MDZ_ROOT>/adapters/claude/hooks/mdz-hook.mjs\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
